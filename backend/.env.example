# Database Configuration
DATABASE_URL="mysql://root:password@localhost:3306/fleet_guardian"

# Security
JWT_SECRET="your_jwt_secret_key_here"

# Server Configuration
PORT=3001
NODE_ENV="production"

# Frontend URL for CORS (comma separated if multiple)
