generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  nom       String
  prenom    String
  username  String   @unique
  email     String   @unique
  password  String
  role               UserRole @default(GESTIONNAIRE)
  actif              Boolean  @default(true)
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  logs      HistoryLog[]

  @@map("users")
}

model Vehicle {
  id                         Int           @id @default(autoincrement())
  immatriculation            String        @unique
  marque                     String
  modele                     String
  annee                      Int
  kilometrage                Int           @default(0)
  statut                     VehicleStatus @default(DISPONIBLE)
  typeCarburant              FuelType      @default(DIESEL)
  capaciteReservoir          Int?
  numeroChassis              String?
  couleur                    String?
  dateAcquisition            DateTime?
  prixAcquisition            Float?
  notes                      String?       @db.Text
  assuranceNumero            String?
  assuranceCompagnie         String?
  assuranceExpiration        DateTime?
  prochainControle           DateTime?
  budgetAlloue               Float?        @default(0)
  budgetConsomme             Float?        @default(0)
  transmission               String        @default("MANUELLE")
  derniereVidangeKilometrage Int           @default(0)
  frequenceVidange           Int           @default(5000)
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  maintenances               Maintenance[]
  vouchers                   FuelVoucher[]
  alerts                     Alert[]
  fuelRecords                FuelRecord[]
  missions                   Mission[]

  @@map("vehicles")
}

model BudgetAllocation {
  id             Int            @id @default(autoincrement())
  vehiculeId     Int
  montant        Float
  annee          Int
  dateAllocation DateTime       @default(now())
  commentaire    String?        @db.Text
  type           AllocationType @default(ANNUEL)

  @@index([vehiculeId], map: "budget_allocations_vehiculeId_fkey")
  @@map("budget_allocations")
}

model Driver {
  id               Int          @id @default(autoincrement())
  nom              String
  prenom           String
  permisNumero     String       @unique
  permisExpiration DateTime
  permisCategories String?
  telephone        String
  statut           DriverStatus @default(DISPONIBLE)
  dateNaissance    DateTime?
  adresse          String?
  notes            String?      @db.Text
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  missions         Mission[]

  @@map("drivers")
}

model Mission {
  id                      Int           @id @default(autoincrement())
  vehiculeId              Int
  chauffeurId             Int
  destination             String
  objectif                String?       @db.Text
  dateDepart              DateTime
  dateRetour              DateTime?
  kmDepart                Int           @default(0)
  kmRetour                Int?
  statut                  MissionStatus @default(PLANIFIEE)
  observationDepart       String?       @db.Text
  observationRetour       String?       @db.Text
  observations            String?       @db.Text
  typeCarburantDotation   String?
  carteCarburantId        Int?
  montantCarburantUtilise Float?
  ticketCarburantUrl      String?
  lettreMission           String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  vehicule                Vehicle       @relation(fields: [vehiculeId], references: [id])
  chauffeur               Driver        @relation(fields: [chauffeurId], references: [id])
  vouchers                FuelVoucher[]

  @@index([chauffeurId], map: "missions_chauffeurId_fkey")
  @@index([vehiculeId], map: "missions_vehiculeId_fkey")
  @@map("missions")
}

model FuelCard {
  id             Int            @id @default(autoincrement())
  numero         String         @unique
  solde          Float          @default(0)
  soldeInitial   Float
  prixLitre      Float?
  prixDiesel     Float?         @default(675)
  prixSuper      Float?         @default(750)
  litresEstimes  Float?
  dateExpiration DateTime
  statut         FuelCardStatus @default(ACTIVE)
  fournisseur    String?
  station        String?
  notes          String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  fuelRecords    FuelRecord[]   @relation("CardFuelRecords")
  maintenances   Maintenance[]  @relation("CardMaintenances")

  @@map("fuel_cards")
}

model FuelVoucher {
  id             Int               @id @default(autoincrement())
  numero         String            @unique
  valeur         Float
  dateEmission   DateTime
  dateExpiration DateTime?
  statut         FuelVoucherStatus @default(DISPONIBLE)
  station        String?
  vehiculeId     Int?
  missionId      Int?
  notes          String?           @db.Text
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  vehicule       Vehicle?          @relation(fields: [vehiculeId], references: [id])
  mission        Mission?          @relation(fields: [missionId], references: [id])
  fuelRecords    FuelRecord[]      @relation("VoucherFuelRecords")
  maintenances   Maintenance[]     @relation("VoucherMaintenances")

  @@index([missionId], map: "fuel_vouchers_missionId_fkey")
  @@index([vehiculeId], map: "fuel_vouchers_vehiculeId_fkey")
  @@map("fuel_vouchers")
}

model FuelRecord {
  id               Int           @id @default(autoincrement())
  vehiculeId       Int
  date             DateTime
  quantite         Float
  montant          Float
  prixLitre        Float?
  kilometrage      Int
  typeCarburant    FuelType
  station          String?
  modePaiement     PaymentMethod
  carteCarburantId Int?
  bonEssenceId     Int?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  vehicule         Vehicle       @relation(fields: [vehiculeId], references: [id])
  carteCarburant   FuelCard?     @relation("CardFuelRecords", fields: [carteCarburantId], references: [id])
  bonEssence       FuelVoucher?  @relation("VoucherFuelRecords", fields: [bonEssenceId], references: [id])

  @@index([bonEssenceId], map: "fuel_records_bonEssenceId_fkey")
  @@index([carteCarburantId], map: "fuel_records_carteCarburantId_fkey")
  @@index([vehiculeId], map: "fuel_records_vehiculeId_fkey")
  @@map("fuel_records")
}

model Maintenance {
  id                Int                      @id @default(autoincrement())
  vehiculeId        Int
  type              MaintenanceType
  description       String                   @db.Text
  dateDebut         DateTime
  dateFin           DateTime?
  montant           Float?
  statut            MaintenanceStatus        @default(EN_ATTENTE)
  garage            String?
  notes             String?                  @db.Text
  mainDoeuvre       Float?                   @default(0)
  sourceMainDoeuvre MaintenancePaymentSource @default(VEHICLE_BUDGET)
  modePaiement      PaymentMethod?           @default(ESPECES)
  carteCarburantId  Int?
  bonEssenceId      Int?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  vehicule          Vehicle                  @relation(fields: [vehiculeId], references: [id])
  carteCarburant    FuelCard?                @relation("CardMaintenances", fields: [carteCarburantId], references: [id])
  bonEssence        FuelVoucher?             @relation("VoucherMaintenances", fields: [bonEssenceId], references: [id])
  items             MaintenanceItem[]

  @@index([bonEssenceId], map: "maintenances_bonEssenceId_fkey")
  @@index([carteCarburantId], map: "maintenances_carteCarburantId_fkey")
  @@index([vehiculeId], map: "maintenances_vehiculeId_fkey")
  @@map("maintenances")
}

model MaintenanceItem {
  id             Int                      @id @default(autoincrement())
  maintenanceId  Int
  nom            String
  reference      String?
  quantite       Int                      @default(1)
  prixUnitaire   Float
  total          Float
  sourcePaiement MaintenancePaymentSource @default(VEHICLE_BUDGET)
  maintenance    Maintenance              @relation(fields: [maintenanceId], references: [id])

  @@index([maintenanceId], map: "maintenance_items_maintenanceId_fkey")
  @@map("maintenance_items")
}

model Alert {
  id           Int           @id @default(autoincrement())
  type         String
  message      String        @db.Text
  module       AlertModule
  severity     AlertSeverity @default(WARNING)
  lue          Boolean       @default(false)
  vehiculeId   Int?
  dateCreation DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  vehicule     Vehicle?      @relation(fields: [vehiculeId], references: [id])

  @@index([vehiculeId], map: "alerts_vehiculeId_fkey")
  @@map("alerts")
}

model HistoryLog {
  id            Int      @id @default(autoincrement())
  action        String
  module        String
  details       String?  @db.Text
  utilisateurId Int?
  entiteId      Int?
  entiteType    String?
  createdAt     DateTime @default(now())
  utilisateur   User?    @relation(fields: [utilisateurId], references: [id])

  @@index([utilisateurId], map: "history_logs_utilisateurId_fkey")
  @@map("history_logs")
}

model SystemSettings {
  id                    Int      @id @default(1)
  nomEntreprise         String   @default("Fleet Guardian")
  devise                String   @default("FCFA")
  alerteStockCarburant  Int      @default(10000)
  seuilVidangeKm        Int      @default(5000)
  relanceAssuranceJours Int      @default(15)
  relanceVisiteJours    Int      @default(15)
  budgetGlobalVehicules Float    @default(0)
  budgetGlobalCarburant Float    @default(0)
  budgetGlobalCartes    Float    @default(0)
  budgetGlobalBons      Float    @default(0)
  updatedAt             DateTime @updatedAt

  @@map("system_settings")
}

model GlobalBudgetActivity {
  id          Int      @id @default(autoincrement())
  field       String
  amount      Float
  type        String   @default("REPLENISHMENT")
  date        DateTime @default(now())
  description String?  @db.Text

  @@map("global_budget_activities")
}

enum UserRole {
  ROOT_ADMIN
  ADMIN
  GESTIONNAIRE
  USER
}

enum VehicleStatus {
  DISPONIBLE
  EN_MISSION
  EN_MAINTENANCE
  HORS_SERVICE
}

enum FuelType {
  ESSENCE
  DIESEL
  ELECTRIQUE
  HYBRIDE
}

enum AllocationType {
  ANNUEL
  SUPPLEMENTAIRE
}

enum DriverStatus {
  DISPONIBLE
  EN_MISSION
  INACTIF
}

enum MissionStatus {
  PLANIFIEE
  EN_COURS
  TERMINEE
  ANNULEE
}

enum FuelCardStatus {
  ACTIVE
  INACTIVE
  EXPIREE
  EN_MISSION
}

enum FuelVoucherStatus {
  DISPONIBLE
  UTILISE
  EXPIRE
}

enum PaymentMethod {
  CARTE_CARBURANT
  BON_ESSENCE
  ESPECES
  CARTE_BANCAIRE
}

enum MaintenancePaymentSource {
  VEHICLE_BUDGET
  FUEL_CARD
  FUEL_VOUCHER
  CASH
}

enum MaintenanceType {
  PANNE
  REPARATION
  VIDANGE
  ASSURANCE
  VISITE_TECHNIQUE
  AUTRE
}

enum MaintenanceStatus {
  EN_ATTENTE
  EN_COURS
  TERMINEE
  ANNULEE
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertModule {
  VEHICULE
  CHAUFFEUR
  MISSION
  CARBURANT
  MAINTENANCE
  BUDGET
}
